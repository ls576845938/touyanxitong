APP_NAME=AlphaRadar
ENV=local
DATABASE_URL=sqlite:///./alpha_radar.db
# PostgreSQL example:
# DATABASE_URL=postgresql+psycopg://alpha:alpha@localhost:5432/alpha_radar
DATABASE_POOL_PRE_PING=true
MOCK_DATA=true
MARKET_DATA_SOURCE=mock
# Optional market-aware source chain. Empty uses free-only built-in defaults:
# A=tencent,yahoo,baostock,akshare
# HK=tencent,yahoo,akshare
# US=yahoo,akshare
MARKET_DATA_PROVIDER_CHAIN=
ALLOW_MOCK_FALLBACK=true
ENABLED_MARKETS=A,US,HK
MAX_STOCKS_PER_MARKET=50
MARKET_DATA_PERIODS=320
AUTO_RUN_PIPELINE_ON_STARTUP=false
OPENAI_API_KEY=
TUSHARE_TOKEN=
POLYGON_API_KEY=
TIINGO_API_KEY=
EODHD_API_KEY=
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
